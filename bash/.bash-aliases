### general
alias ..='cd ..'
alias ::='. ~/.bashrc'
alias c="clear"
alias cl="c;l"
alias cll="c;ll"

### GIT
alias gs="git status"
alias gb="git branch"
alias gpl="git pull"
alias gaa="git add ."
alias gpu="git push"
alias grv="git remote -v"
alias gf="git fetch" # will fetch remote changes to local repo WITHOUT merging
alias gbr="git branch -r" # list of remote branches

### dotfiles
alias lib="cd $LIB"
alias dot="cd $DOT"

### files and dest
alias dl="cd $HOME/Downloads"
alias doc="cd $HOME/Documents"

### WSL (delete later)
alias pr="cd $HOME/projects"

### SCRIPTS
alias fpr=". fpr.sh"
